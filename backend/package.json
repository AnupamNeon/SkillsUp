{
  "name": "role-lms-backend",
  "version": "2.0.0",
  "description": "Role-based Learning Management System API with RBAC, search, pagination, and production-ready architecture",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/ server.js --ext .js",
    "lint:fix": "eslint src/ server.js --ext .js --fix",
    "test": "NODE_ENV=test jest --passWithNoTests",
    "test:watch": "NODE_ENV=test jest --watch"
  },
  "keywords": [
    "lms",
    "learning-management-system",
    "education",
    "rbac",
    "express",
    "mongodb",
    "rest-api",
    "clerk",
    "stripe"
  ],
  "author": "Anupam",
  "license": "MIT",
  "dependencies": {
    "@clerk/express": "^1.7.76",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "mongoose": "^9.2.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "stripe": "^20.4.0",
    "svix": "^1.86.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
