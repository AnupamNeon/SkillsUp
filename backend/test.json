    {
      "name": "2. Public Course Routes",
      "item": [
        {
          "name": "Get All Courses (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.items && res.items.length > 0) {",
                  "        pm.collectionVariables.set('courseId', res.items[0]._id);",
                  "        console.log('First course ID saved:', res.items[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/course/all?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "course", "all"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "react",
                  "disabled": true
                },
                {
                  "key": "minPrice",
                  "value": "0",
                  "disabled": true
                },
                {
                  "key": "maxPrice",
                  "value": "100",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Course By ID (Public)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/course/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "course", "{{courseId}}"]
            }
          }
        }
      ]
    },
