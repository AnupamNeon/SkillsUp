                  "src": "/path/to/thumbnail.jpg",
                  "description": "Course thumbnail image"
                },
                {
                  "key": "courseData",
                  "value": "{\n  \"courseTitle\": \"Complete React Development 2024\",\n  \"courseDescription\": \"Master React with hooks, context, and real projects\",\n  \"coursePrice\": 49.99,\n  \"discount\": 20,\n  \"courseContent\": [\n    {\n      \"chapterId\": \"ch-001\",\n      \"chapterOrder\": 0,\n      \"chapterTitle\": \"Introduction to React\",\n      \"chapterContent\": [\n        {\n          \"lectureId\": \"lec-001\",\n          \"lectureTitle\": \"What is React?\",\n          \"lectureDuration\": 15,\n          \"lectureUrl\": \"https://www.youtube.com/watch?v=dGcsHMXbSOA\",\n          \"isPreviewFree\": true,\n          \"lectureOrder\": 0,\n          \"lectureDescription\": \"Introduction to React framework and its core concepts\"\n        }\n      ]\n    }\n  ]\n}",
                  "type": "text"
