            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    if (res.courseId) {",
                  "        pm.collectionVariables.set('courseId', res.courseId);",
                  "        console.log('New course ID saved:', res.courseId);",
