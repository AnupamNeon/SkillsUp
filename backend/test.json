      "item": [
        {
          "name": "Sync User (First Time Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.user && res.user._id) {",
                  "        pm.collectionVariables.set('userId', res.user._id);",
                  "        console.log('User ID saved:', res.user._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "sync"]
